POST 127.0.0.1: 11000/eeprom/read

请求体：
{
    "ip": "10.150.12.151",
    "slot_id":1,                                      // slot_id板id是由上位机计算好的(slot_id=ip最后一位-150),我们下位机直接拿来用即可，不用再算一遍了
    "data": [
        {
            "address": "000000C0", // 读取的起始地址位
            "length": 64 // 读取长度(目前实际长度就只有32，64，256位这三种，后续如果有其他长度需求，再增加即可)
        },
        {
            "address": "000000E0", // 读取的起始地址位
            "length": 64
        },
        {
            "address": "000000F0", // 读取的起始地址位
            "length": 32
        },
        {
            "address": "00000100", // 读取的起始地址位
            "length": 256
        }
        // .... 其他
    ]
}


成功响应：
{
    "statusCode": "200", // 如果读取错误，此处需约定其他错误码，如：500
    "message": "read success", // 如果读取错误，需在此处说明原因
    "data": [
        {
            "address": "000000C0", // 读取的起始地址位
            "data": "41414142ffffffff" // 读取到的数据(16进制类似这样的)// 读取长度为64位，未写入数据部分上位机会补FF
        },
        {
            "address": "000000E0", // 读取的起始地址位
            "data": "4142fffff142f142" // 读取到的数据
        },
        {
            "address": "000000F0", // 读取的起始地址位
            "data": "4141ffff" // 读取到的数据(16进制类似这样的)
        },
        {
            "address": "00000100", // 读取的起始地址位
            "data": "41414141...ffff" // 读取到的数据(16进制类似这样的)，长度为256字节，未写入数据部分上位机会补FF
        }
        // ... 其他
    ]
}

错误响应：
{
    "statusCode": "500", // 可约定其他错误码
    "message": "unable xxxx" // 错误原因
}


