POST 127.0.0.1: 11000/eeprom/write

请求体：
{
    "ip": "10.150.12.152",
    "slot_id":2,                                  // slot_id板id是由上位机计算好的(slot_id=ip最后一位-150),我们下位机直接拿来用即可，不用再算一遍了
    "data": [
        {
            "address": "000000C0", // 写入的起始地址位
            "length":64,           //写入数据的长度64位
            "data": "41414142ffffffff" // 写入数据  长度 = length
        },
        {
            "address": "000000E0", // 写入的起始地址位
            "length": 64,          // 写入数据的长度64位
            "data": "14142ffff14142ff" // 写入数据
        },
        {
            "address": "000000F0", // 写入的起始地址位
            "length": 32,          // 写入数据的长度32位
            "data": "41414141" // 写入数据
        },
        {
            "address": "00000100", // 写入的起始地址位
            "length": 256,         // 写入数据的长度
            "data": "41414141...ffff" // 写入数据，长度为256字节
        }
        // ... 其他写入数据
    ]
}


响应：
{
    "statusCode": "200", // 如果写入错误，此处需约定其他错误码，如：500
    "message": "write success" // 如果写入错误，需在此处说明原因
}


